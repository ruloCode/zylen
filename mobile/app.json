{
  "expo": {
    "name": "Zylen",
    "slug": "zylen",
    "version": "1.2.1",
    "scheme": "zylen",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rulocode.zylen",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.rulocode.zylen",
      "versionCode": 3,
      "adaptiveIcon": {
        "backgroundColor": "#0B1519",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-font",
      "expo-image",
      "expo-build-properties",
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B1519",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#14b8a6"
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6f728ba9-6a94-4f05-be4c-390aa179962d"
      }
    },
    "owner": "rulocode97"
  }
}
