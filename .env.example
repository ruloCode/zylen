# ===========================
# Supabase Configuration
# ===========================
# Get these values from your Supabase project dashboard:
# https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/api
#
# IMPORTANT: These are the same values for both local development and production.
# The app uses the same Supabase project in all environments.

# Your Supabase project URL
# Example: https://dpjtatyrikecynptytgn.supabase.co
VITE_SUPABASE_URL=your-project-url.supabase.co

# Your Supabase anonymous/public key (safe to expose in client)
# This is a public key that can be safely committed to your repo
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================
# OAuth Configuration
# ===========================
# OAuth redirects are handled automatically based on window.location.origin:
# - Local dev: http://localhost:5173/auth/callback
# - Production: https://your-domain.vercel.app/auth/callback
#
# Make sure BOTH URLs are configured in:
# 1. Supabase Dashboard > Auth > URL Configuration > Redirect URLs
# 2. Google Cloud Console > OAuth Client > Authorized JavaScript origins
#
# See docs/OAUTH_LOCAL_SETUP.md for detailed setup instructions

# ===========================
# OpenAI Configuration
# ===========================
# Get your API key from: https://platform.openai.com/api-keys
# This key powers the AI Coach chat page (/chat)
VITE_OPENAI_API_KEY=your-openai-api-key-here

# ===========================
# Hermes Agent Configuration
# ===========================
# Powers the "Coach Personal" chat opened from the Dashboard. Hermes exposes an
# OpenAI-compatible API; the chat POSTs to {VITE_HERMES_API_URL}/chat/completions
# and streams the response via SSE.
#
# Base URL of the local Hermes API server (OpenAI-compatible /v1 base).
VITE_HERMES_API_URL=http://localhost:8642/v1
# Bearer token used to authenticate against the Hermes API server.
VITE_HERMES_API_KEY=your-hermes-api-key-here

# ===========================
# Development helpers
# ===========================
# DEV ONLY: skip Supabase auth and run with a local mock user + mock data.
# Only honored when import.meta.env.DEV is true (never in production builds).
# VITE_SKIP_AUTH=true

# SECURITY NOTE: every VITE_* variable is embedded in the client bundle at
# build time and visible to users. VITE_OPENAI_API_KEY in particular is
# exposed in the browser — for production, proxy the chat through a backend
# (e.g. a Supabase Edge Function) instead of shipping the key. Tracked as a
# post-v1 hardening task.
